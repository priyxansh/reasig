# ReaSig Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (required)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM Model (OpenRouter)
REASIG_MODEL=openai/gpt-oss-120b:free

# Daemon Settings (optional)
REASIG_HOST=127.0.0.1
REASIG_PORT=9876

# Temp directory for rendered audio (optional, defaults to system temp)
# REASIG_TEMP_DIR=/tmp/reasig
