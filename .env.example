# ReaBot Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (required)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM Model (optional, defaults to free Llama 3.1 70B)
# Free models: meta-llama/llama-3.1-70b-instruct:free, mistralai/mistral-7b-instruct:free
REABOT_MODEL=meta-llama/llama-3.1-70b-instruct:free

# Daemon Settings (optional)
REABOT_HOST=127.0.0.1
REABOT_PORT=9876

# Temp directory for rendered audio (optional, defaults to system temp)
# REABOT_TEMP_DIR=/tmp/reabot
